# Database
POSTGRES_USER=spamproxy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=spamproxy
# DATABASE_URL wird automatisch pro Service gesetzt (mail-service: asyncpg, web: pg)
# Nur überschreiben wenn nötig:

# Web Interface
NEXTAUTH_SECRET=generate-a-secret-here
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# SMTP Proxy
PROXY_HOSTNAME=proxy.example.com
# Backend-Server werden per Domain im Web-Interface konfiguriert.
# Fallback wenn keine Domain-Route gefunden wird:
SMTP_BACKEND_HOST=mail.example.com
SMTP_BACKEND_PORT=25

# rspamd
RSPAMD_URL=http://rspamd:11333
RSPAMD_PASSWORD=changeme

# AI Classification
AI_PROVIDER=openai
AI_API_KEY=sk-your-key-here
AI_MODEL=gpt-4o-mini
# For Ollama:
# AI_PROVIDER=ollama
# AI_URL=http://ollama:11434
# AI_MODEL=llama3

# Quarantine
QUARANTINE_RETENTION_DAYS=30

# Federation
# Bind-Adresse fuer rspamd Federation-Ports (11333, 11335)
# 0.0.0.0 = von aussen erreichbar (Firewall schützt per IP)
# 127.0.0.1 = nur lokal (kein Federation möglich)
FEDERATION_BIND=0.0.0.0

# Redis (production)
# REDIS_PASSWORD=changeme
